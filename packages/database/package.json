{
  "name": "@formbricks/database",
  "packageManager": "pnpm@11.7.0",
  "private": true,
  "version": "0.1.0",
  "main": "./dist/index.cjs",
  "types": "./dist/index.d.ts",
  "type": "module",
  "sideEffects": false,
  "files": [
    "dist",
    "generated",
    "schema.prisma"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./types/*": {
      "types": "./types/*.ts",
      "import": "./types/*.ts"
    },
    "./errors": {
      "types": "./dist/src/errors.d.ts",
      "import": "./dist/src/errors.js",
      "require": "./dist/src/errors.cjs"
    },
    "./prisma": {
      "types": "./dist/src/prisma.d.ts",
      "import": "./dist/src/prisma.js",
      "require": "./dist/src/prisma.cjs"
    },
    "./prisma-browser": {
      "types": "./dist/src/prisma-browser.d.ts",
      "import": "./dist/src/prisma-browser.js",
      "require": "./dist/src/prisma-browser.cjs"
    },
    "./prisma-adapter": {
      "types": "./dist/src/prisma-adapter.d.ts",
      "import": "./dist/src/prisma-adapter.js",
      "require": "./dist/src/prisma-adapter.cjs"
    },
    "./zod/*": {
      "types": "./zod/*.ts",
      "import": "./zod/*.ts"
    }
  },
  "scripts": {
    "clean": "rimraf .turbo node_modules dist",
    "build": "pnpm generate && vite build && tsc -p tsconfig.generated-prisma.json",
    "dev": "vite build --watch",
    "db:migrate:deploy": "node ./dist/scripts/apply-migrations.js",
    "db:migrate:dev": "pnpm build && dotenv -e ../../.env -- sh -c \"pnpm generate && node ./dist/scripts/apply-migrations.js\"",
    "db:create-saml-database:deploy": "env SAML_DATABASE_URL=\"${SAML_DATABASE_URL}\" node ./dist/scripts/create-saml-database.js",
    "db:create-saml-database:dev": "dotenv -e ../../.env -- node ./dist/scripts/create-saml-database.js",
    "db:push": "prisma db push --accept-data-loss",
    "db:seed": "dotenv -e ../../.env -- tsx src/seed.ts",
    "db:seed:clear": "dotenv -e ../../.env -- tsx src/seed.ts --clear",
    "db:setup": "pnpm db:migrate:dev && pnpm db:create-saml-database:dev",
    "db:start": "pnpm db:setup",
    "format": "prisma format",
    "generate": "node ./src/scripts/clean-generated-prisma.mjs && prisma generate",
    "lint": "eslint ./src --fix",
    "generate-data-migration": "tsx ./src/scripts/generate-data-migration.ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "create-migration": "dotenv -e ../../.env -- tsx ./src/scripts/create-migration.ts"
  },
  "dependencies": {
    "@formbricks/i18n-utils": "workspace:*",
    "@formbricks/logger": "workspace:*",
    "@formbricks/types": "workspace:*",
    "@paralleldrive/cuid2": "2.3.1",
    "@prisma/adapter-pg": "7.8.0",
    "@prisma/client": "7.8.0",
    "bcryptjs": "3.0.3",
    "pg": "8.16.3",
    "uuid": "14.0.0",
    "zod": "4.3.6",
    "zod-openapi": "5.4.6"
  },
  "devDependencies": {
    "@formbricks/config-typescript": "workspace:*",
    "@formbricks/eslint-config": "workspace:*",
    "@types/pg": "8.16.0",
    "dotenv-cli": "11.0.0",
    "glob": "13.0.6",
    "prisma": "7.8.0",
    "prisma-json-types-generator": "4.1.1",
    "tsx": "4.21.0",
    "vite": "7.3.5",
    "vite-plugin-dts": "4.5.4",
    "vitest": "4.1.6"
  }
}
