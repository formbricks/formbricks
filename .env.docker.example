# Docker Environment Variables
# Copy this file to .env.docker and fill in your values
# Usage: docker-compose --env-file .env.docker -f docker-compose.local.yml up

########################################
# REQUIRED - GENERATE THESE SECRETS
########################################

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=
ENCRYPTION_KEY=
CRON_SECRET=

########################################
# MEMBER LOOKUP API CONFIGURATION
########################################

# API Key for member lookup endpoint
# Generate with: openssl rand -base64 32
MEMBER_LOOKUP_API_KEY=

# Snowflake Connection Details
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USERNAME=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=PUBLIC
SNOWFLAKE_WAREHOUSE=
